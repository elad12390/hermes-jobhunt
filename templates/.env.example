# Hermes .env example
# Copy to ~/.hermes/.env and fill in your values

# ── LLM Providers ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# OPENROUTER_API_KEY=sk-or-YOUR_KEY_HERE

# ── Telegram ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE          # from @BotFather
TELEGRAM_ALLOWED_USERS=YOUR_TELEGRAM_USER_ID    # from @userinfobot
TELEGRAM_HOME_CHANNEL=YOUR_TELEGRAM_USER_ID     # your DM channel (same as above)

# ── Job Pipeline ───────────────────────────────────────────────
OBSIDIAN_VAULT_PATH=/path/to/your/ObsidianVault

# Residential proxy (optional, for LinkedIn scraping)
# LINKEDIN_PROXY_URL=http://USERNAME:PASSWORD@PROXY_HOST:PORT

# LinkedIn search tuning (all optional - sensible defaults apply)
# LINKEDIN_LOCATION=United States              # location name for the query
# LINKEDIN_GEO_ID=                             # LinkedIn geoId for the location
# LINKEDIN_SEARCHES=Senior Backend Engineer,AI Engineer,Backend Developer
# LINKEDIN_MAX_JOBS=10                          # max jobs per search
# LINKEDIN_MAX_HOURS=2                          # only jobs posted within N hours

# ── Google OAuth (set by setup.py, don't edit manually) ────────
# GOOGLE_TOKEN_PATH=~/.hermes/google_token.json
